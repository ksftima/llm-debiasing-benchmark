Bootstrap: docker
From: ubuntu:22.04

%environment
    export DEBIAN_FRONTEND=noninteractive

%post
    export DEBIAN_FRONTEND=noninteractive

    # Base system tools + all system libs needed by current CRAN packages
    apt-get update && apt-get install -y --no-install-recommends \
        wget \
        software-properties-common \
        dirmngr \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libfontconfig1-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libjpeg-dev \
        libtiff5-dev \
        libwebp-dev \
        cmake \
        libnlopt-dev \
        pkg-config \
        gfortran
    rm -rf /var/lib/apt/lists/*

    # Add CRAN repo for R 4.4+ (correct key URL — marutter_pubkey.asc, no @ in filename)
    wget -qO- https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc \
        | tee /etc/apt/trusted.gpg.d/cran_ubuntu_key.asc
    echo "deb https://cloud.r-project.org/bin/linux/ubuntu jammy-cran40/" \
        > /etc/apt/sources.list.d/r-cran.list
    apt-get update && apt-get install -y --no-install-recommends r-base r-base-dev
    rm -rf /var/lib/apt/lists/*

    Rscript -e "install.packages('remotes', repos='https://cloud.r-project.org')"
    # Fail fast: verify nloptr compiles before proceeding — it unblocks lme4 and arm
    Rscript -e "install.packages('nloptr', repos='https://cloud.r-project.org')"
    Rscript -e "library('nloptr')"
    Rscript -e "remotes::install_github('naoki-egami/dsl', dependencies=TRUE)"
    Rscript -e "library('dsl')"
