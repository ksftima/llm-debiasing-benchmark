# Section 1: The header
Bootstrap: docker
From: ubuntu:22.04

# Section 2: Files
%files
    requirements_container.txt /opt/requirements_container.txt

%environment
    export DEBIAN_FRONTEND=noninteractive
    export LC_ALL=C
    export PYTHONUNBUFFERED=1

%post
    export DEBIAN_FRONTEND=noninteractive

    # Base system tools + all system libs needed by current CRAN packages
    apt-get update && apt-get install -y --no-install-recommends \
        python3-dev \
        python3-pip \
        gcc \
        g++ \
        wget \
        software-properties-common \
        dirmngr \
        libcurl4-openssl-dev \
        libssl-dev \
        libxml2-dev \
        libfontconfig1-dev \
        libharfbuzz-dev \
        libfribidi-dev \
        libfreetype6-dev \
        libpng-dev \
        libjpeg-dev \
        libtiff5-dev \
        libwebp-dev \
        cmake \
        libnlopt-dev \
        pkg-config \
        gfortran
    rm -rf /var/lib/apt/lists/*

    # Add CRAN repo for R 4.4+ (correct key URL — marutter_pubkey.asc, no @ in filename)
    wget -qO- https://cloud.r-project.org/bin/linux/ubuntu/marutter_pubkey.asc \
        | tee /etc/apt/trusted.gpg.d/cran_ubuntu_key.asc
    echo "deb https://cloud.r-project.org/bin/linux/ubuntu jammy-cran40/" \
        > /etc/apt/sources.list.d/r-cran.list
    apt-get update && apt-get install -y --no-install-recommends r-base r-base-dev
    rm -rf /var/lib/apt/lists/*

    # R packages: fail fast on nloptr before running the full dsl dependency tree
    Rscript -e "install.packages('remotes', repos='https://cloud.r-project.org')"
    Rscript -e "install.packages('nloptr', repos='https://cloud.r-project.org')"
    Rscript -e "library('nloptr')"

    # Step 1: install original dsl — resolves all dependencies (arm, lme4, grf, etc.)
    Rscript -e "remotes::install_github('naoki-egami/dsl', dependencies=TRUE)"

    # Step 2: overwrite with forked dsl_reg (adds lambda param) — deps already installed
    Rscript -e "remotes::install_github('ksftima/dsl_reg', dependencies=FALSE)"

    # Verify
    Rscript -e "library('dsl')"

    # Pip installs
    pip3 install --upgrade pip
    pip3 install torch --index-url https://download.pytorch.org/whl/cu124
    pip3 install -r /opt/requirements_container.txt

%labels
    Author Kesa Fatima
    Version 0.2
    Description LLM debiasing benchmark with L2 regularization for DSL and PPI

%help
    Development usage (bind-mound code and data at runtime):
        apptainer exec \
            --bind /path/to/thesis:/code \
            --bind /path/to/datasets:/data\
            thesis.sif python /code/script.py

    Interactive shell inside the container:
        apptainer shell --bind /path/to/thesis:/code thesis.sif
